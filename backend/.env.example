# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-long-random-string
SITE_NAME=Cyber Stellar IT

# ── Server ────────────────────────────────────────────────────────────────────
# Port for local dev (Procfile/railway use $PORT in production)
PORT=8100

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank to use SQLite locally (creates site.db inside backend/).
# On Railway/Render, set to the Postgres connection string they give you.
DATABASE_URL=

# ── Company / Invoice Details ────────────────────────────────────────────────
COMPANY_ADDRESS=Your Street, Dhaka, Bangladesh
COMPANY_PHONE=+880 1XXX XXXXXX
COMPANY_WEBSITE=cyberstellarbd.com
# Indicative USD→BDT rate for invoices (USD is shown alongside BDT).
USD_TO_BDT_RATE=120.0

# ── Local Bank Transfer (BDT) ────────────────────────────────────────────────
# Shown to customers at checkout and printed on invoices.
BANK_NAME=
BANK_ACCOUNT_NAME=
BANK_ACCOUNT_NUMBER=
BANK_BRANCH=
BANK_ROUTING=

# ── International Wire Transfer (USD) ────────────────────────────────────────
WIRE_BANK_NAME=
WIRE_ACCOUNT_NAME=
WIRE_ACCOUNT_NUMBER=
WIRE_SWIFT=
WIRE_BANK_ADDRESS=

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Leave SMTP_USER/SMTP_PASSWORD blank to disable email sending (logs only).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Where order/inquiry/payment alerts get sent
ADMIN_EMAIL=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Use * for development. Restrict to your real domain in production.
FRONTEND_ORIGINS=*

# ── Admin Seed (only used the first time seed.py runs) ────────────────────────
# Change these before deploying! The admin user is created from these on first run.
ADMIN_PASSWORD=changeme123
